{
  "name": "saber-admin",
  "version": "3.0.1",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve --mode 23Service",
    "serve:11Service": "vue-cli-service serve --mode 11Service",
    "build": "vue-cli-service build --mode 23Service",
    "build:11Service": "vue-cli-service build --mode 11Service",
    "postinstall": "node scripts/patch-echarts.js",
    "lint": "eslint --fix --ext .js,.vue src",
    "analyz": "npm_config_report=true npm run build",
    "clean": "rimraf dist.zip",
    "test:unit": "vue-cli-service test:unit",
    "test:e2e": "vue-cli-service test:e2e",
    "log": "changelog-sn -i CHANGELOG.md -s -r 2",
    "cz": "git add . && git cz"
  },
  "dependencies": {
    "@antv/data-set": "^0.11.8",
    "@babel/core": "^7.18.13",
    "@babel/preset-env": "^7.18.10",
    "@vue-office/docx": "^1.6.2",
    "@vue-office/pdf": "^2.0.2",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-preset-jsx": "^1.4.0",
    "acharts": "file:../acharts",
    "avue-plugin-ueditor": "^0.1.4",
    "axios": "^0.18.0",
    "babel-plugin-component": "^1.1.1",
    "babel-polyfill": "^6.26.0",
    "cache-loader": "^2.0.1",
    "canvas2svg": "^1.0.16",
    "classlist-polyfill": "^1.2.0",
    "core-js": "^3.39.0",
    "crypto-js": "^4.0.0",
    "dayjs": "^1.11.4",
    "echarts": "^5.5.0",
    "echarts-gl": "^2.0.9",
    "echarts-stat": "^1.2.0",
    "element-plus": "^2.8.8",
    "element-resize-detector": "^1.2.4",
    "gsap": "^3.10.4",
    "html2canvas": "^1.4.1",
    "js-base64": "^2.5.1",
    "js-cookie": "^2.2.0",
    "js-md5": "^0.7.3",
    "leader-line": "^1.0.7",
    "lodash": "^4.17.21",
    "lodash-webpack-plugin": "^0.11.6",
    "mockjs": "^1.0.1-beta3",
    "node-gyp": "^5.0.6",
    "nprogress": "^0.2.0",
    "portfinder": "^1.0.23",
    "script-loader": "^0.7.2",
    "three": "^0.130.0",
    "umy-ui": "^1.1.6",
    "use": "^3.1.1",
    "uuid": "^9.0.0",
    "vue": "^3.5.13",
    "vue-axios": "^2.1.2",
    "vue-cesium": "^2.3.11",
    "vue-cli": "^2.9.6",
    "vue-demi": "^0.14.8",
    "vue-i18n": "^9.14.1",
    "vue-light-timeline": "^1.0.3",
    "vue-router": "^4.4.5",
    "vuex": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": ".\\node_modules\\cz-customizable"
    },
    "cz-customizable": {
      "config": ".\\.czconfigrc.js"
    }
  },
  "devDependencies": {
    "@babel/plugin-proposal-optional-chaining": "^7.18.9",
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.5.13",
    "chai": "^4.1.2",
    "changelog-sn": "^2.2.0",
    "eslint": "^7.32.0",
    "less": "^4.1.3",
    "less-loader": "^6.0.0",
    "postcss": "^8.4.49",
    "postcss-import": "^15.1.0",
    "postcss-pxtorem": "^6.1.0",
    "sass": "1.69.5",
    "sass-loader": "^13.3.3",
    "skeleton-loader": "^2.0.0",
    "standard-version": "^9.5.0",
    "webpack-bundle-analyzer": "^3.0.3"
  },
  "lint-staged": {
    "*.js": [
      "vue-cli-service lint",
      "git add"
    ],
    "*.vue": [
      "vue-cli-service lint",
      "git add"
    ]
  }
}
