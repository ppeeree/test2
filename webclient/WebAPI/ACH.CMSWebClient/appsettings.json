{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // JAVA数据库链接
    "SQLConn": "server=192.168.124.23;port=3306;user=test;password=123456;database=wtphm_1.2;Charset=utf8",
    "theweaveConn": "server=192.168.124.23;port=3306;user=test;password=123456;database=theweave;Charset=utf8",
    "SaveWavePath": "C:\\code\\WaveData"
  },

  // 反向代理
  "ReverseProxy": {
    "Routes": {
      "MapApi": {
        "ClusterId": "MapApi",
        "Match": {
          "Path": "/geoserver/{**catchall}"
        }
      }
    },
    "Clusters": {
      "MapApi": {
        "Destinations": {
          "LocalGeoserver": {
            "Address": "http://localhost:9096"
          }
        }
      }
    }
  },


  "AllowedHosts": "*",

  // 服务端口
  "ServerPort": 5150,

  // 采集服务日志地址（示例：/opt/ACH.GWHADU/ACH.GWHADU.AcqServer/logs）
  "monitorServerPath": "",

  // 诊断数据压缩包，删除多久前的数据：
  "dayZIPDeleteTime": "90", // 天

  // 芯能系统配置项
  "xnTitle": "风机混凝土塔筒在线状态监测系统",
  "xnVersion": "V1.6.8.2",
  "defaultRouter": "/screen", // 需要默认进来是数据下载页面，配置内容为【/basicConfig/dataDownLoad/index】

  // 直流分量报警线
  "DCUpperLine": "18",
  "DCLowerLine": "6",

  // 超声采集单元PPK阈值
  "BFMNormalLine": "6",


  // 是否启动诊断数据下载服务【false为不启动定时服务】
  "StartDownloadService": false,

  // 是否下载金凤数据统计结果【false为不统计金风采集结果】
  "DownloadCountFile": false,
  // 金风文件存储地址，用于统计金风数据统计结果（示例：/opt/ACH.GWHADU/GwTempData）
  "ACHDataDir": "",

  // 状态树取最近XX天内的数据构建
  "RTStatusTreeTime": "60", // 天


  // 调用MonitorServer的接口
  "ClientURL": "http://192.168.124.11:5112"
}
